{
  "rewrites": [
    {
      "source": "/repair",
      "destination": "/repair/index.html"
    },
    {
      "source": "/repair/",
      "destination": "/repair/index.html"
    },
    {
      "source": "/repair/customer/request",
      "destination": "/repair/index.html"
    },
    {
      "source": "/repair/admin",
      "destination": "/repair/index.html"
    },
    {
      "source": "/repair/success",
      "destination": "/repair/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
