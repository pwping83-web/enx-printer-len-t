{
  "rewrites": [
    {
      "source": "/repair",
      "destination": "/repair/index.html"
    },
    {
      "source": "/repair/",
      "destination": "/repair/index.html"
    },
    {
      "source": "/repair/:path*",
      "destination": "/repair/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
